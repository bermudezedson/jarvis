# ─── MCP Server endpoints ────────────────────────────────────────────────────
GMAIL_MCP_URL=https://gmailmcp.googleapis.com/mcp/v1
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-your-client-secret
GMAIL_REFRESH_TOKEN=1//your-refresh-token

CALENDAR_MCP_URL=https://calendarmcp.googleapis.com/mcp/v1
CALENDAR_CLIENT_ID=your-client-id.apps.googleusercontent.com
CALENDAR_CLIENT_SECRET=GOCSPX-your-client-secret
CALENDAR_REFRESH_TOKEN=1//your-refresh-token

JIRA_MCP_URL=https://mcp.atlassian.com/v1/mcp
JIRA_ACCESS_TOKEN=your-atlassian-oauth-token
JIRA_CLOUD_ID=your-cloud-id-here
JIRA_USER_EMAIL=hablemos@clickrepuestos.cl

CONFLUENCE_MCP_URL=https://mcp.atlassian.com/v1/mcp
CONFLUENCE_ACCESS_TOKEN=your-atlassian-oauth-token

# ─── API server ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Claude API (skill ai-classifier) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Timezone ─────────────────────────────────────────────────────────────────
TZ=America/Santiago
